
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Publicly readable
    match /products/{id} { allow read: if true; allow write: if isAdmin(); }
    match /blog_posts/{id} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id} { allow read: if true; allow write: if isAdmin(); }
    match /certifications/{id} { allow read: if true; allow write: if isAdmin(); }

    // Inquiry & RFQ Submissions (Allow public creation)
    match /inquiries/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    match /rfq_submissions/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Portal Features: Data Isolation
    match /orders/{id} {
      allow read: if isOwner(resource.data.buyerUid) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /sample_requests/{id} {
      allow read: if isOwner(resource.data.buyerUid) || isAdmin();
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.buyerUid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /access_requests/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /roles_admin/{uid} {
      allow get: if isSignedIn();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
