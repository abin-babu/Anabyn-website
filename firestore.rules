rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /catalogue_leads/{leadId} {
      allow create: if true; // Public submission
      allow read, update, delete: if isAdmin();
    }

    match /roles_admin/{adminUid} {
      allow get: if request.auth.uid == adminUid;
    }
    
    // Existing rules for other collections...
    match /{document=**} {
      allow read, write: if false;
    }
  }
}