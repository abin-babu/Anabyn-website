
/**
 * @fileOverview Firestore Security Rules for Anabyn Global Ventures.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model.
 * - Public read access for product catalog (products, categories).
 * - Inquiries can be created by anyone, but can only be read and managed by authenticated administrators.
 * - Admin user profiles are private.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Publicly readable product and category data. Only admins can write.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    match /categories/{categoryId} {
        allow get, list: if true;
        allow write: if isAdmin();
    }

    /**
     * @description Inquiries can be created by anyone. Read/update/delete is restricted to admins.
     */
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    /**
     * @description Admin user profiles are private and only accessible to the corresponding authenticated user.
     */
    match /admin/{userId} {
      allow get, write: if isOwner(userId);
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user.
     * @return {boolean} True if authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the document.
     * @param {string} userId - The user ID to check against.
     * @return {boolean} True if the authenticated user is the owner.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is an admin by checking for their existence in the /admin collection.
     * @return {boolean} True if the user is an admin.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }
  }
}
