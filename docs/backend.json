
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Comprehensive product information for the catalogue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string", "enum": ["hospitality-supplies", "medical-supplies"] },
        "subcategory": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "specifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "materials": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "gsm": { "type": "string" },
              "tc": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "moqPieces": { "type": "number" },
        "moqKg": { "type": "number" },
        "sampleAvailable": { "type": "boolean" },
        "privateLabelAvailable": { "type": "boolean" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "hsCode": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "type": "object",
      "description": "SEO-optimized articles for content marketing.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Export Guides", "Industry Insights", "Product Updates", "Trade News"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "string" },
            "avatar": { "type": "string" }
          }
        },
        "publishedAt": { "type": "string", "format": "date-time" },
        "readingTime": { "type": "number" },
        "featuredImage": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Buyer orders and shipment tracking.",
      "properties": {
        "orderId": { "type": "string" },
        "buyerUid": { "type": "string" },
        "product": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["Processing", "Shipped", "Delivered"] },
        "trackingNumber": { "type": "string" },
        "carrier": { "type": "string" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "RFQSubmission": {
      "title": "RFQ Submission",
      "type": "object",
      "properties": {
        "rfqId": { "type": "string" },
        "category": { "type": "string" },
        "product": { "type": "string" },
        "quantity": { "type": "number" },
        "destinationCountry": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "In Progress", "Quoted", "Closed"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Product catalog data."
    },
    "/blog_posts/{postId}": {
      "schema": "#/backend/entities/BlogPost",
      "description": "Articles and news."
    },
    "/testimonials/{id}": {
      "description": "Customer reviews."
    },
    "/certifications/{id}": {
      "description": "Compliance certificates."
    },
    "/rfq_submissions/{id}": {
      "schema": "#/backend/entities/RFQSubmission",
      "description": "Buyer quote requests."
    },
    "/orders/{orderId}": {
      "schema": "#/backend/entities/Order",
      "description": "Customer orders."
    },
    "/clients/{id}": {
      "description": "Partner logos."
    },
    "/shipping_routes/{id}": {
      "description": "Logistics data."
    },
    "/hs_codes/{id}": {
      "description": "Harmonized System codes."
    }
  },
  "storage": {
    "/certificates/": { "description": "PDF certificates for public viewing." },
    "/products/images/": { "description": "High-res product photography." },
    "/client-logos/": { "description": "Partner corporate logos." },
    "/buyer-portal/documents/": { "description": "Confidential order documents per buyer." },
    "/blog/images/": { "description": "Article featured images." }
  }
}
