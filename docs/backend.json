
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Comprehensive product information for the catalogue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string", "enum": ["hospitality-supplies", "medical-supplies"] },
        "subcategory": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "specifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "materials": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "gsm": { "type": "string" },
              "tc": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "moqPieces": { "type": "number" },
        "moqKg": { "type": "number" },
        "sampleAvailable": { "type": "boolean" },
        "privateLabelAvailable": { "type": "boolean" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "hsCode": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "type": "object",
      "description": "SEO-optimized articles for content marketing.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Export Guides", "Industry Insights", "Product Updates", "Trade News"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "string" },
            "avatar": { "type": "string" }
          }
        },
        "publishedAt": { "type": "string", "format": "date-time" },
        "readingTime": { "type": "number" },
        "featuredImage": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean" }
      },
      "required": ["slug", "title", "content", "category", "author"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "type": "object",
      "description": "Verified customer reviews and social proof.",
      "properties": {
        "clientName": { "type": "string" },
        "designation": { "type": "string" },
        "company": { "type": "string" },
        "country": { "type": "string" },
        "countryFlag": { "type": "string" },
        "rating": { "type": "number" },
        "testimonialText": { "type": "string" },
        "productCategory": { "type": "string" },
        "orderYear": { "type": "number" },
        "photoUrl": { "type": "string", "format": "uri" },
        "linkedinUrl": { "type": "string", "format": "uri" },
        "verified": { "type": "boolean" },
        "featured": { "type": "boolean" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Partner logos and corporate clients.",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "sector": { "type": "string", "enum": ["Hotels & Resorts", "Hospitals & Clinics", "Distributors"] },
        "featured": { "type": "boolean" }
      }
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Company compliance and verification documents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "issuedBy": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "code": { "type": "string", "description": "Identifier like IEC or GSTIN" },
        "category": { "type": "string", "enum": ["quality", "compliance"] },
        "number": { "type": "string" },
        "verifyUrl": { "type": "string", "format": "uri" }
      },
      "required": ["name", "fileUrl", "issuedBy", "verified"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Product catalog data."
    },
    "/blog_posts/{postId}": {
      "schema": "#/backend/entities/BlogPost",
      "description": "Articles and news."
    },
    "/testimonials/{testimonialId}": {
      "schema": "#/backend/entities/Testimonial",
      "description": "Customer reviews."
    },
    "/clients/{clientId}": {
      "schema": "#/backend/entities/Client",
      "description": "Partner and client logos."
    },
    "/certificates/{certificateId}": {
      "schema": "#/backend/entities/Certificate",
      "description": "Publicly readable company certificates."
    },
    "/rfq_submissions/{rfqId}": {
      "schema": "#/backend/entities/RFQSubmission",
      "description": "Buyer quote requests."
    },
    "/audit_requests/{requestId}": {
      "schema": "#/backend/entities/AuditRequest",
      "description": "Requests for full audit reports."
    }
  }
}
