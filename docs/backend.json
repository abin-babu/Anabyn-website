
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Comprehensive product information for the catalogue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string", "enum": ["hospitality-supplies", "medical-supplies"] },
        "subcategory": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "specifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "materials": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "gsm": { "type": "string" },
              "tc": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "moqPieces": { "type": "number" },
        "moqKg": { "type": "number" },
        "sampleAvailable": { "type": "boolean" },
        "privateLabelAvailable": { "type": "boolean" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "hsCode": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "type": "object",
      "description": "SEO-optimized articles for content marketing.",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["Export Guides", "Industry Insights", "Product Updates", "Trade News"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "role": { "type": "string" },
            "avatar": { "type": "string" }
          }
        },
        "publishedAt": { "type": "string", "format": "date-time" },
        "readingTime": { "type": "number" },
        "featuredImage": { "type": "string", "format": "uri" },
        "featured": { "type": "boolean" }
      },
      "required": ["slug", "title", "content", "category", "author"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Company compliance and verification documents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "issuedBy": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "code": { "type": "string", "description": "Identifier like IEC or GSTIN" },
        "category": { "type": "string", "enum": ["quality", "compliance"] },
        "number": { "type": "string" },
        "verifyUrl": { "type": "string", "format": "uri" }
      },
      "required": ["name", "fileUrl", "issuedBy", "verified"]
    },
    "RFQSubmission": {
      "title": "RFQSubmission",
      "type": "object",
      "description": "Multi-step quote request from potential buyers.",
      "properties": {
        "rfqId": { "type": "string" },
        "category": { "type": "string" },
        "product": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "destinationCountry": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "incoterm": { "type": "string" },
        "customization": {
          "type": "object",
          "properties": {
            "oem": { "type": "boolean" },
            "customSize": { "type": "string" },
            "customColor": { "type": "string" },
            "certifications": { "type": "array", "items": { "type": "string" } },
            "sampleRequired": { "type": "boolean" },
            "referenceImageUrl": { "type": "string" }
          }
        },
        "userDetails": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "company": { "type": "string" },
            "designation": { "type": "string" },
            "email": { "type": "string" },
            "whatsapp": { "type": "string" },
            "country": { "type": "string" },
            "source": { "type": "string" },
            "notes": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["New", "In Progress", "Quoted", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AuditRequest": {
      "title": "AuditRequest",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Product catalog data."
    },
    "/blog_posts/{postId}": {
      "schema": "#/backend/entities/BlogPost",
      "description": "Articles and news."
    },
    "/certificates/{certificateId}": {
      "schema": "#/backend/entities/Certificate",
      "description": "Publicly readable company certificates."
    },
    "/rfq_submissions/{rfqId}": {
      "schema": "#/backend/entities/RFQSubmission",
      "description": "Buyer quote requests."
    },
    "/audit_requests/{requestId}": {
      "schema": "#/backend/entities/AuditRequest",
      "description": "Requests for full audit reports."
    }
  }
}
