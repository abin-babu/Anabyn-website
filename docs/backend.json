
{
  "entities": {
    "Certificate": {
      "title": "Certificate",
      "description": "Company compliance and verification documents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "issuedBy": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "code": { "type": "string", "description": "Identifier like IEC or GSTIN" }
      },
      "required": ["name", "fileUrl", "issuedBy", "verified"]
    },
    "CompanyProfile": {
      "title": "CompanyProfile",
      "type": "object",
      "description": "Stores general company information.",
      "properties": {
        "id": { "type": "string" },
        "establishmentYear": { "type": "number" },
        "headquartersLocation": { "type": "string" },
        "iecCode": { "type": "string" },
        "gstin": { "type": "string" },
        "cin": { "type": "string" },
        "msmeRegistered": { "type": "boolean" },
        "registeredAddress": { "type": "string" },
        "directors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "linkedin": { "type": "string" },
              "photo": { "type": "string" }
            }
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "year": { "type": "string" },
              "event": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/certificates/{certificateId}": {
      "schema": "#/backend/entities/Certificate",
      "description": "Publicly readable company certificates."
    },
    "/company_profile/main": {
      "schema": "#/backend/entities/CompanyProfile",
      "description": "Main company profile information."
    }
  }
}
