{
  "entities": {
    "CatalogueLead": {
      "title": "CatalogueLead",
      "description": "Represents a lead generated from a catalogue download request.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string" },
        "country": { "type": "string" },
        "productInterest": { "type": "array", "items": { "type": "string" } },
        "orderVolume": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "source": { "type": "string" }
      },
      "required": ["name", "email", "company", "country", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/catalogue_leads/{leadId}": {
      "schema": "CatalogueLead",
      "description": "Collection of trade leads from the catalogue download form."
    }
  }
}