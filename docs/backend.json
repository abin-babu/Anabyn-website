
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the Anabyn Premium Gallery.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "slug": {
          "type": "string",
          "description": "The URL-friendly slug for the product."
        },
        "categoryId": {
          "type": "string",
          "description": "The ID of the category this product belongs to."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "images": {
          "type": "array",
          "description": "An array of image URLs for the product.",
          "items": {
            "type": "string"
          }
        },
        "specifications": {
          "type": "object",
          "properties": {
            "size": {
              "type": "string"
            },
            "material": {
              "type": "string"
            },
            "gsm": {
              "type": "string"
            },
            "tc": {
              "type": "string"
            },
            "color": {
              "type": "string"
            }
          }
        },
        "customizationOptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "moq": {
          "type": "string",
          "description": "Minimum Order Quantity for the product."
        },
        "published": {
          "type": "boolean",
          "description": "Indicates whether the product is published or not."
        },
        "shortSpecs": {
          "type": "string",
          "description": "A short summary of the product's key specifications."
        }
      },
      "required": [
        "name",
        "slug",
        "categoryId",
        "description",
        "images",
        "shortSpecs"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a product category or subcategory.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        },
        "imageUrl": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "slug"
      ]
    },
    "Inquiry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inquiry",
      "type": "object",
      "description": "Represents an inquiry made by a customer.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the person making the inquiry."
        },
        "company": {
          "type": "string",
          "description": "The company of the person making the inquiry."
        },
        "email": {
          "type": "string",
          "description": "The email address of the person making the inquiry.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the person making the inquiry."
        },
        "message": {
          "type": "string",
          "description": "The message included in the inquiry."
        },
        "products": {
          "type": "array",
          "description": "An array of product IDs and quantities included in the inquiry.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "qty": {
                "type": "number"
              }
            }
          }
        },
        "status": {
          "type": "string",
          "description": "The status of the inquiry (Enquired, Under Discussion, Order Confirmed, Shipped, Completed)."
        },
        "createdAt": {
          "type": "string",
          "description": "The date and time the inquiry was created.",
          "format": "date-time"
        }
      },
      "required": [
        "name",
        "email",
        "message",
        "status",
        "createdAt"
      ]
    },
    "Admin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Admin",
      "type": "object",
      "description": "Represents an admin user with access to the dashboard.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Admin entity. This matches the Firebase Auth UID."
        },
        "name": {
          "type": "string",
          "description": "The name of the admin user."
        },
        "email": {
          "type": "string",
          "description": "The email address of the admin user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the admin user."
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/entities/Product"
          },
          "description": "Stores individual product details."
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": {
            "$ref": "#/entities/Category"
          },
          "description": "Stores product categories and subcategories."
        }
      },
      {
        "path": "/inquiries/{inquiryId}",
        "definition": {
          "entityName": "Inquiry",
          "schema": {
            "$ref": "#/entities/Inquiry"
          },
          "description": "Stores customer inquiries and quote requests."
        }
      },
      {
        "path": "/admin/{uid}",
        "definition": {
          "entityName": "Admin",
          "schema": {
            "$ref": "#/entities/Admin"
          },
          "description": "Stores admin user profiles. The document ID is the Firebase Auth UID."
        }
      }
    ]
  }
}
