
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Comprehensive product information for the catalogue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string", "enum": ["hospitality-supplies", "medical-supplies"] },
        "subcategory": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "specifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "materials": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "gsm": { "type": "string" },
              "tc": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "moqPieces": { "type": "number" },
        "moqKg": { "type": "number" },
        "sampleAvailable": { "type": "boolean" },
        "privateLabelAvailable": { "type": "boolean" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "hsCode": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Company compliance and verification documents.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "issuedBy": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "verified": { "type": "boolean" },
        "icon": { "type": "string", "description": "Lucide icon name" },
        "code": { "type": "string", "description": "Identifier like IEC or GSTIN" },
        "category": { "type": "string", "enum": ["quality", "compliance"] },
        "number": { "type": "string" },
        "verifyUrl": { "type": "string", "format": "uri" }
      },
      "required": ["name", "fileUrl", "issuedBy", "verified"]
    },
    "CompanyProfile": {
      "title": "CompanyProfile",
      "type": "object",
      "description": "Stores general company information.",
      "properties": {
        "id": { "type": "string" },
        "establishmentYear": { "type": "number" },
        "headquartersLocation": { "type": "string" },
        "iecCode": { "type": "string" },
        "gstin": { "type": "string" },
        "cin": { "type": "string" },
        "msmeRegistered": { "type": "boolean" },
        "registeredAddress": { "type": "string" },
        "directors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "linkedin": { "type": "string" },
              "photo": { "type": "string" }
            }
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "year": { "type": "string" },
              "event": { "type": "string" }
            }
          }
        }
      }
    },
    "AuditRequest": {
      "title": "AuditRequest",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "country": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ShippingRoute": {
      "title": "ShippingRoute",
      "type": "object",
      "properties": {
        "region": { "type": "string" },
        "port": { "type": "string" },
        "transitTime": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "HSCode": {
      "title": "HSCode",
      "type": "object",
      "properties": {
        "product": { "type": "string" },
        "code": { "type": "string" }
      }
    },
    "MOQData": {
      "title": "MOQData",
      "type": "object",
      "properties": {
        "product": { "type": "string" },
        "moq": { "type": "string" },
        "leadTime": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Product catalog data."
    },
    "/certificates/{certificateId}": {
      "schema": "#/backend/entities/Certificate",
      "description": "Publicly readable company certificates."
    },
    "/company_profile/main": {
      "schema": "#/backend/entities/CompanyProfile",
      "description": "Main company profile information."
    },
    "/audit_requests/{requestId}": {
      "schema": "#/backend/entities/AuditRequest",
      "description": "Requests for full audit reports."
    },
    "/shipping_routes/{routeId}": {
      "schema": "#/backend/entities/ShippingRoute",
      "description": "Information about global shipping routes."
    },
    "/hs_codes/{codeId}": {
      "schema": "#/backend/entities/HSCode",
      "description": "Harmonized System codes for products."
    },
    "/moq_data/{dataId}": {
      "schema": "#/backend/entities/MOQData",
      "description": "MOQ and lead time information per product."
    }
  }
}
