
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Comprehensive product information for the catalogue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string", "enum": ["hospitality-supplies", "medical-supplies"] },
        "subcategory": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "specifications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "materials": { "type": "array", "items": { "type": "string" } },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "size": { "type": "string" },
              "gsm": { "type": "string" },
              "tc": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "moqPieces": { "type": "number" },
        "moqKg": { "type": "number" },
        "sampleAvailable": { "type": "boolean" },
        "privateLabelAvailable": { "type": "boolean" },
        "certifications": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "hsCode": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "featured": { "type": "boolean" },
        "active": { "type": "boolean" }
      }
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Buyer orders and shipment tracking.",
      "properties": {
        "orderId": { "type": "string" },
        "buyerUid": { "type": "string" },
        "companyName": { "type": "string" },
        "product": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "status": { "type": "string", "enum": ["Processing", "In Production", "QC Passed", "Shipped", "Delivered"] },
        "trackingNumber": { "type": "string" },
        "carrier": { "type": "string" },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "note": { "type": "string" }
            }
          }
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SampleRequest": {
      "title": "Sample Request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerUid": { "type": "string" },
        "productName": { "type": "string" },
        "status": { "type": "string", "enum": ["Requested", "Dispatched", "Received", "Closed"] },
        "rating": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Product catalog data."
    },
    "/orders/{orderId}": {
      "schema": "#/backend/entities/Order",
      "description": "Customer orders."
    },
    "/sample_requests/{id}": {
      "schema": "#/backend/entities/SampleRequest",
      "description": "Product sample requests from portal."
    },
    "/access_requests/{id}": {
      "description": "Requests for portal access from new buyers."
    }
  },
  "storage": {
    "/buyer-portal/documents/{uid}/": { "description": "Confidential order documents per buyer." }
  }
}
